# 로컬 개발: 기본은 아래처럼 백엔드 직접 호출.
# VITE_API_BASE_URL=http://localhost:8000
#
# 로컬에서 "동일 출처 + 프록시"로 쓰려면 빈 값 → vite가 /api 를 localhost:8000 으로 넘김.
# VITE_API_BASE_URL=
#
# 배포(HTTPS) 빌드: 반드시 공개 백엔드 HTTPS URL(끝 / 없음). localhost로 빌드한 채 업로드하면 연결 실패.
# VITE_API_BASE_URL=https://korea-worldcup.onrender.com
#
# 또는 정적 호스팅에서 /api 를 백엔드로 프록시한 뒤 빌드 시 빈 값.
# VITE_API_BASE_URL=
VITE_API_BASE_URL=http://localhost:8000
