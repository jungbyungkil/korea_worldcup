# npm run build 시 적용. 이 파일을 .env.production 으로 복사한 뒤 값만 채우세요.
# 백엔드가 Render 등 HTTPS 이면 그 루트 URL (끝 / 없음)
VITE_API_BASE_URL=https://your-api.onrender.com

# --- 모바일(같은 Wi-Fi)에서 PC 백엔드만 쓸 때 예시 ---
# PC IP가 192.168.0.10 이고 uvicorn이 0.0.0.0:8000 이면:
# VITE_API_BASE_URL=http://192.168.0.10:8000
# (휴대폰 브라우저는 빌드된 프론트 주소로 열고, API만 위 주소로 감)

# 정적 호스팅이 /api 를 백엔드로 프록시하면 빈 값:
# VITE_API_BASE_URL=
