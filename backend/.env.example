API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# 2026 페이지 AI 의견 (POST /worldcup2026/ai-opinion)
# 국대 선수 화면 베스트 11 (POST /worldcup2026/korea/best-xi) 동일 키 사용
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 리그 ID 고정 (선택) — DATA-SOURCES.md 참고
# API_FOOTBALL_AFC_QUALIFIERS_LEAGUE_ID=
# API_FOOTBALL_LEAGUE_IDS=

# --- 국대 선수 feature (/api/v1/worldcup2026/korea/player-features) ---
# 부상 API에 넣는 시즌 연도 (국대 team 기준)
API_FOOTBALL_INJURY_SEASON=2025
# 스쿼드 중 통계를 붙일 최대 인원 (API 호출량 ↑)
API_FOOTBALL_PLAYER_FEATURE_LIMIT=25
# 클럽 리그 시즌 통계(players?id=) 포함 — 0/false 끔
API_FOOTBALL_PLAYER_INCLUDE_CLUB_STATS=true
# 최근 국대 경기 라인업 — 호출 많음, 기본 끔. true 로 켜기
API_FOOTBALL_PLAYER_INCLUDE_LINEUPS=false
# 라인업을 가져올 최근 경기 수 (최대 10)
API_FOOTBALL_LINEUP_FIXTURES=2
# 집계 응답 캐시(초)
API_FOOTBALL_PLAYER_FEATURES_CACHE_SEC=300
