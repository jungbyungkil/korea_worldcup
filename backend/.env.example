API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- API-Football 보완 (선택) — /api/v1/worldcup2026/supplement/* ---
# Football-Data.org v4 (https://www.football-data.org/) — 월드컵 일정 등, 무료 티어 쿼터·대회 제한 있음
FOOTBALL_DATA_ORG_TOKEN=

# TheSportsDB v1 무료: https://www.thesportsdb.com/documentation — URL에 키 포함 (예: .../json/123/searchteams.php)
# 비우면 공식 무료 키 123 사용. 프리미엄은 프로필 키를 여기에 넣으면 됩니다.
THESPORTSDB_API_KEY=
# (선택) FIFA 월드컵 리그 ID — 한국 이력 상세·하이라이트 조회용. 기본 4429
# THESPORTSDB_WC_LEAGUE_ID=4429

# Sportmonks v3 (https://www.sportmonks.com/) — 팀 검색 등, 토큰 없으면 해당 엔드포인트 501
SPORTMONKS_API_TOKEN=

# 한국 대표팀 화면 베스트 11 등 (POST /worldcup2026/korea/best-xi) — OpenAI 호환 API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# (선택) 정적 스쿼드 JSON의 ``sofifa_id`` → CDN 초상 URL 조합 시 FC 에디션 접두 (예: 26 = FC26). 기본 26.
# SOFIFA_CDN_IMG_VER=26

# 리그 ID 고정 (선택) — DATA-SOURCES.md 참고
# API_FOOTBALL_AFC_QUALIFIERS_LEAGUE_ID=
# API_FOOTBALL_LEAGUE_IDS=

# --- 한국 대표팀 선수 feature (/api/v1/worldcup2026/korea/player-features) ---
# 자동 검색 실패 시에만: API-Sports에서 한국( Korea Republic ) 국가대표 team id 를 넣으면 검색을 건너뜁니다.
# API_FOOTBALL_TEAM_ID_KOREA=
# 자동 검색·국가 조회가 모두 실패할 때만 쓰는 NT id (기본 17). 끄려면 아래를 1 로 두세요.
# API_FOOTBALL_DISABLE_KOREA_NT_FALLBACK=0
# API_FOOTBALL_KOREA_NT_FALLBACK_TEAM_ID=17
# 부상 API에 넣는 시즌 연도 (대표팀 team 기준)
API_FOOTBALL_INJURY_SEASON=2025
# 1/true 이면 위 시즌 부상이 비었을 때 직전 시즌(season-1)을 한 번 더 조회 (국가대표는 첫 시즌이 빈 경우가 많음)
# API_FOOTBALL_INJURY_TRY_PREV_SEASON=1
# 스쿼드 중 통계를 붙일 최대 인원 (API 호출량 ↑)
# 본선 스쿼드 최대 26명(2026 WC) — 클럽 통계를 붙일 스쿼드 상한
API_FOOTBALL_PLAYER_FEATURE_LIMIT=26
# 클럽 리그 시즌 통계(players?id=) 포함 — 0/false 끔
API_FOOTBALL_PLAYER_INCLUDE_CLUB_STATS=true
# 최근 대표팀 경기 라인업 — 호출 많음, 기본 끔. true 로 켜기
API_FOOTBALL_PLAYER_INCLUDE_LINEUPS=false
# 라인업을 가져올 최근 경기 수 (최대 10)
API_FOOTBALL_LINEUP_FIXTURES=2
# 집계 응답 캐시(초)
API_FOOTBALL_PLAYER_FEATURES_CACHE_SEC=300

# --- 멕시코 대표팀 (/api/v1/worldcup2026/mexico/player-features) ---
# 자동 검색 실패 시에만: API-Sports에서 멕시코 남자 국가대표 team id (대개 16) 를 넣으면 검색을 건너뜁니다.
# API_FOOTBALL_TEAM_ID_MEXICO=16
# 예시 선발 11인에 클럽 통계 붙임 — 0/false 끔
API_FOOTBALL_MEXICO_INCLUDE_CLUB_STATS=true
# 멕시코 집계 캐시(초)
API_FOOTBALL_MEXICO_FEATURES_CACHE_SEC=300

# --- 남아공 대표팀 (/api/v1/worldcup2026/south-africa/player-features) ---
# 자동 검색 실패 시에만: API-Sports 남아공 국가대표 team id (대시보드에서 teams 검색으로 확인)
# API_FOOTBALL_TEAM_ID_SOUTH_AFRICA=
API_FOOTBALL_SOUTH_AFRICA_INCLUDE_CLUB_STATS=true
API_FOOTBALL_SOUTH_AFRICA_FEATURES_CACHE_SEC=300

# --- 체코 대표팀 · A조 1차전 (/api/v1/worldcup2026/czech-republic/player-features) ---
# 레거시 URL group-a-playoff-d 는 동일 페이로드·캐시를 사용합니다.
# 자동 검색 실패 시에만: API-Sports 체코 남자 국가대표 team id (대개 770 전후 — 대시보드 teams 검색으로 확인)
# API_FOOTBALL_TEAM_ID_CZECH_REPUBLIC=
API_FOOTBALL_CZECH_REPUBLIC_INCLUDE_CLUB_STATS=true
API_FOOTBALL_CZECH_REPUBLIC_FEATURES_CACHE_SEC=300
